+    def test_alias_is_default_pickle_roundtrip(self):
+        """
+        alias_is_default survives pickle round-tripping.
+        """
+
+        @attrs.define
+        class C:
+            auto: int
+            explicit: int = attrs.field(alias="custom")
+
+        fields = attr.fields(C)
+
+        for a in fields:
